# --- AI & News API Keys ---
OPENAI_API_KEY=your_openai_api_key_here
NEWS_API_KEY=your_news_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here
GNEWS_API_KEY_2=your_optional_secondary_gnews_key

# --- Groq API Keys (Optional but recommended for speed) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# --- Specialized Groq Keys (Optional for regional news) ---
GROQ_KEY_TELUGU=
GROQ_KEY_HINDI=
GROQ_KEY_MALAYALAM=
GROQ_KEY_TAMIL=
GROQ_KEY_CRYSTAL_BALL=

# --- Translation Keys (Optional) ---
TRANSLATION_OPENAI_KEY_1=
TRANSLATION_OPENAI_KEY_2=
TRANSLATION_OPENAI_KEY_3=

# --- Firebase Configuration ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# If using a service account JSON instead of individual env vars:
FIREBASE_SERVICE_ACCOUNT_JSON=service-account.json

# --- Push Notifications (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Application Settings ---
PORT=7860
DATABASE_URL=sqlite:///data/news.db
DATA_DIR_PATH=data
SCHEDULE_TIME=06:00
